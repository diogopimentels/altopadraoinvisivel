# ==========================================
# ⚠️ ATENÇÃO: NUNCA COLOQUE SUAS CHAVES REAIS AQUI!
# Este é apenas um arquivo de exemplo para referência.
# ==========================================

# [FRONTEND] Chave Pública do Stripe
# É seguro expor no lado do cliente (Começa com pk_test_ ou pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_sua_chave_publica_aqui

# [BACKEND] Chave Secreta do Stripe
# 🛑 NUNCA EXPONHA ESTA CHAVE NO FRONTEND! (Começa com sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta_aqui

# [BACKEND] Chave do Webhook do Stripe
# 🛑 NUNCA EXPONHA ESTA CHAVE NO FRONTEND! (Começa com whsec_)
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_de_webhook_aqui

# [BACKEND] Senha do Painel Administrativo
# Usada para proteger a rota /admin
ADMIN_PASSWORD=sua_senha_super_segura_aqui

# [FRONTEND/BACKEND] Supabase Keys
# Necessário para conectar com o banco de dados e armazenamento de imagens
NEXT_PUBLIC_SUPABASE_URL=sua_url_do_supabase_aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_do_supabase_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
